# Code owners.
#
# The `.github/` directory contains workflows — the most privileged code in
# the repo, since it can execute with our credentials and (via release.yml)
# mint OIDC tokens that publish to npm. Treat workflow changes like
# security-relevant code: only the core maintainers can approve them.

* @daloyjs/maintainers

# Workflow / CI / CD — strictly maintainers.
/.github/                         @daloyjs/maintainers
/.github/workflows/               @daloyjs/maintainers
/.github/workflows/release.yml    @daloyjs/maintainers
/.github/dependabot.yml           @daloyjs/maintainers
/.github/CODEOWNERS               @daloyjs/maintainers

# Anything that affects what gets shipped to npm.
/package.json                     @daloyjs/maintainers
/pnpm-lock.yaml                   @daloyjs/maintainers
/pnpm-workspace.yaml              @daloyjs/maintainers
/.npmrc                           @daloyjs/maintainers
/packages/create-daloy/package.json @daloyjs/maintainers

# Security policy and incident notes.
/SECURITY.md                      @daloyjs/maintainers
/SECURITY-CONTACTS.md             @daloyjs/maintainers
/otherdocs/security-incidence.md  @daloyjs/maintainers
